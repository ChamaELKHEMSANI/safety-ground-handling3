# Configuration Application
APP_ENV=development
APP_DEBUG=true
APP_NAME="Simulateur Sécurité"

# API
API_URL=/data/pistes.xml
API_TIMEOUT=5000

# Cache
CACHE_TTL=86400000
CACHE_ENABLED=true

# Storage
STORAGE_ENABLED=true
STORAGE_VERSION=1

# Features
FEATURE_EXPORT=true
FEATURE_COMPARE=true
FEATURE_ADMIN=true
FEATURE_OFFLINE=true

# Logging
LOG_LEVEL=info
LOG_TO_CONSOLE=true

# Analytics (Optional)
GA_ID=
